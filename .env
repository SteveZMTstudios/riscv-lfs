
# !!!
# 请勿盲目复制粘贴以下内容！
# 你应该下载这个脚本，在记事本中打开，然后按需修改它以适应你的环境和需求。


# 清理当前环境，并以干净的环境启动一个新的bash shell
sudo ln -sf bash /bin/sh
exec env -i HOME=$HOME TERM=$TERM PS1='\u:\w\$ ' /bin/bash

# 在那之后，复制以下命令单独执行：
# 设置核心环境变量
export PATH=/usr/bin
if [ ! -L /bin ]; then export PATH=/bin:$PATH; fi
export PATH=$LFS/tools/bin:$PATH

set +h
umask 022
alias sh='bash'
export CLFS=/opt/clfs
export LFS=/opt/clfs
export LC_ALL=POSIX
export CLFS_TGT=riscv64-lfs-linux-gnu
export LFS_TGT=riscv64-lfs-linux-gnu
export ARCH=riscv64

# 如果是构建内核，则应当是：
#export ARCH=riscv

# WARNING 没有LFS_TARGET这种写法

export CONFIG_SITE=$LFS/usr/share/config.site
export LFS LC_ALL LFS_TGT PATH CONFIG_SITE


export MAKEFLAGS="-j$(nproc)"

# 验证
clear
echo "LFS=$LFS"
echo "CLFS=$CLFS"
echo "LFS_TGT=$LFS_TGT"
echo "CLFS_TGT=$CLFS_TGT"
echo "PATH=$PATH"
echo "MAKEFLAGS=$MAKEFLAGS"












# chroot part
# Tell QEMU where to find RISC-V libraries
export QEMU_LD_PREFIX=/opt/clfs

export LFS=/opt/clfs

cp /usr/bin/qemu-riscv64-static $LFS/usr/bin/

chroot "$LFS" /usr/bin/env -i \
    HOME=/root \
    TERM="$TERM" \
    PS1='(lfs chroot) \u:\w\$ ' \
    PATH=/usr/bin:/usr/sbin \
    MAKEFLAGS="-j$(nproc)" \
    TESTSUITEFLAGS="-j$(nproc)" \
    /bin/bash --login -i +h

# 完整的 chroot方法：
export LFS=/opt/clfs

mount -v --bind /dev $LFS/dev
mount -vt devpts devpts -o gid=5,mode=0620 $LFS/dev/pts
mount -vt proc proc $LFS/proc
mount -vt sysfs sysfs $LFS/sys
mount -vt tmpfs tmpfs $LFS/run

if [ -h $LFS/dev/shm ]; then
  install -v -d -m 1777 $LFS$(realpath /dev/shm)
else
  mount -vt tmpfs -o nosuid,nodev tmpfs $LFS/dev/shm
fi

# 干净的chroot：
chroot "$LFS" /usr/bin/qemu-riscv64-static /usr/bin/env -i \
    HOME=/root \
    TERM="$TERM" \
    PS1='(lfs chroot) \u:\w\$ ' \
    PATH=/usr/bin:/usr/sbin \
    MAKEFLAGS="-j$(nproc)" \
    TESTSUITEFLAGS="-j$(nproc)" \
    /bin/bash --login -i +h



# 我更喜欢下面我自己写的这个chroot，
# 它可以在标题上显示它在运行什么，还可以以彩色显示命令的退出状态。
# 如果你在用支持 ANSI 转义序列的终端（例如 Windows Terminal）中使用它
# ，你会发现它非常有用。
# 尤其是批量处理安装包时。
    
chroot "$LFS" /usr/bin/qemu-riscv64-static /usr/bin/env -i \
    HOME=/root \
    TERM="$TERM" \
    PROMPT_COMMAND='_EXIT=$?; if [ -z "$_SET" ]; then trap '"'"'printf "\\033]0;%s\\007" "$BASH_COMMAND"'"'"' DEBUG; _SET=1; fi; printf "\\033]0;lfs chroot: %s\\007" "$PWD"' \
    PS1='$(if [ ${_EXIT:-0} -eq 0 ]; then printf "\[\033[32m\]0\[\033[0m\] "; else printf "\[\033[31m\]%s\[\033[0m\]\[\a\] " "$_EXIT"; fi)(lfs chroot) \u:\[\033[36m\]\w\[\033[0m\]\[\033[33m\]\$\[\033[0m\] ' \
    PATH=/usr/bin:/usr/sbin \
    MAKEFLAGS="-j$(nproc)" \
    TESTSUITEFLAGS="-j$(nproc)" \
    /bin/bash --login -i +h
