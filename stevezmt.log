17:25:08 构建GCC Pass 1

17:25:34 run
cd $CLFS/sources

# 解压并准备 GCC 依赖
tar -xf gcc-14.3.0.tar.xz
tar -xf mpfr-4.2.2.tar.xz && mv -v mpfr-4.2.2 gcc-14.3.0/mpfr
tar -xf gmp-6.3.0.tar.xz && mv -v gmp-6.3.0 gcc-14.3.0/gmp
tar -xf mpc-1.3.1.tar.gz && mv -v mpc-1.3.1 gcc-14.3.0/mpc

mkdir gcc-build && cd gcc-build

../gcc-14.3.0/configure \
    --prefix=$CLFS/cross-tools \
    --target=riscv64-lfs-linux-gnu \
    --with-glibc-version=2.43 \
    --with-sysroot=$CLFS \
    --with-newlib \
    --without-headers \
    --enable-default-pie \
    --enable-default-ssp \
    --disable-nls \
    --disable-shared \
    --disable-multilib \
    --disable-threads \
    --disable-libatomic \
    --disable-libgomp \
    --disable-libquadmath \
    --disable-libssp \
    --disable-libvtv \
    --disable-libstdcxx \
    --enable-languages=c,c++ \
    CFLAGS="-O2 -pipe" \
    CXXFLAGS="-O2 -pipe" \
    2>&1 | tee gcc-config.log

make -j$(nproc) 2>&1 | tee gcc-build.log
make install -j$(nproc) 2>&1 | tee -a gcc-build.log

# 创建 limits.h
cd ..
cat gcc/limitx.h gcc/glimits.h gcc/limity.h > \
    $(dirname $(riscv64-lfs-linux-gnu-gcc -print-libgcc-file-name))/include/limits.h

# 验证
riscv64-lfs-linux-gnu-gcc --version | head -1

