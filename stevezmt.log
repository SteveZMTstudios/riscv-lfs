install -v -m755 -d /usr/share/doc/openssh-10.2p1
install -v -m644 INSTALL LICENCE OVERVIEW README* /usr/share/doc/openssh-10.2p1
ssh-keygen -A
systemctl enable sshd
cd /tmp && rm -rf openssh-10.2p1
echo "--- openssh OK ---"

# Done
umount /sources
