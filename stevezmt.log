ip link set eth0 up
ip route add default via 10.0.2.2 2>/dev/null
echo "nameserver 10.0.2.3" > /etc/resolv.conf

# Mount
mount /dev/vdb /sources

# 1. libtasn1-4.21.0
cd /tmp && tar -xf /sources/libtasn1-4.21.0.tar.gz && cd libtasn1-4.21.0
./configure --prefix=/usr --disable-static
make -j$(nproc) && make install && ldconfig
cd /tmp && rm -rf libtasn1-4.21.0
echo "--- libtasn1 OK ---"

# 2. p11-kit-0.26.2
cd /tmp && tar -xf /sources/p11-kit-0.26.2.tar.xz && cd p11-kit-0.26.2
sed '20,$ d' -i trust/trust-extract-compat
cat >> trust/trust-extract-compat << "EOF"
/usr/libexec/make-ca/copy-trust-modifications
/usr/sbin/make-ca -r
EOF
mkdir p11-build && cd p11-build
meson setup .. --prefix=/usr --buildtype=release -D trust_paths=/etc/pki/anchors
ninja -j$(nproc) && ninja install
ln -sfv /usr/libexec/p11-kit/trust-extract-compat /usr/bin/update-ca-certificates
ldconfig
cd /tmp && rm -rf p11-kit-0.26.2
echo "--- p11-kit OK ---"

# 3. make-ca-1.16.1
cd /tmp && tar -xf /sources/make-ca-1.16.1.tar.gz && cd make-ca-1.16.1
sed '/mktemp/s/-t //' -i make-ca
make install && install -vdm755 /etc/ssl/local
/usr/sbin/make-ca -g
systemctl enable update-pki.timer
mkdir -pv /etc/profile.d
cat > /etc/profile.d/pythoncerts.sh << "EOF"
export _PIP_STANDALONE_CERT=/etc/pki/tls/certs/ca-bundle.crt
EOF
cd /tmp && rm -rf make-ca-1.16.1
echo "--- make-ca OK ---"

# 4. wget-1.25.0
cd /tmp && tar -xf /sources/wget-1.25.0.tar.gz && cd wget-1.25.0
./configure --prefix=/usr --sysconfdir=/etc --with-ssl=openssl
make -j$(nproc) && make install
cd /tmp && rm -rf wget-1.25.0
echo "--- wget OK ---"

# 5. cmake-4.2.3
cd /tmp && tar -xf /sources/cmake-4.2.3.tar.gz && cd cmake-4.2.3
sed -i '/"lib64"/s/64//' Modules/GNUInstallDirs.cmake
./bootstrap --prefix=/usr --system-libs --mandir=/share/man \
  --no-system-jsoncpp --no-system-cppdap --no-system-librhash \
  --no-system-curl --no-system-libarchive --no-system-libuv --no-system-nghttp2 \
  --docdir=/share/doc/cmake-4.2.3
make -j$(nproc) && make install
cd /tmp && rm -rf cmake-4.2.3
echo "--- cmake OK ---"

# 6. fastfetch-2.47.0
cd /tmp && tar -xf /sources/fastfetch-2.47.0.tar.gz && cd fastfetch-2.47.0
mkdir build && cd build
cmake .. -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr
make -j$(nproc) && make install
cd /tmp && rm -rf fastfetch-2.47.0
echo "--- fastfetch OK ---"

# 7. openssh-10.2p1
install -v -g sys -m700 -d /var/lib/sshd
groupadd -g 50 sshd 2>/dev/null || true
useradd -c 'sshd PrivSep' -d /var/lib/sshd -g sshd -s /bin/false -u 50 sshd 2>/dev/null || true
