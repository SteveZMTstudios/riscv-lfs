cd $CLFS/sources
tar -xf binutils-2.44.tar.xz
mkdir binutils-build && cd binutils-build

../binutils-2.44/configure \
    --prefix=$CLFS/cross-tools \
    --with-sysroot=$CLFS \
    --target=riscv64-lfs-linux-gnu \
    --disable-nls \
    --enable-gprofng=no \
    --disable-werror \
    --enable-new-dtags \
    --enable-default-hash-style=gnu

make -j$(nproc)
make install -j$(nproc)

# 验证
riscv64-lfs-linux-gnu-ld --version | head -1

