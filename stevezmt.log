# 下载并构建 tre（正则表达式库）
cd /sources
wget https://github.com/laurikari/tre/releases/download/v0.9.0/tre-0.9.0.tar.gz

cd /tmp
tar -xf /sources/tre-0.9.0.tar.gz
cd tre-0.9.0
./configure --prefix=/usr --disable-static
make -j$(nproc) && make install && ldconfig
cd /tmp && rm -rf tre-0.9.0

# 重试 elinks
cd /tmp
tar -xf /sources/elinks-0.18.0.tar.xz && cd elinks-0.18.0

meson setup build --prefix=/usr --buildtype=release \
  -D utf-8=true \
  -D openssl=true \
  -D sysconfdir=/etc/elinks

ninja -C build -j$(nproc)
ninja -C build install

cd /tmp && rm -rf elinks-0.18.0
echo "--- elinks OK ---"